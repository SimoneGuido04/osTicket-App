<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Trust system CAs and user-installed CAs (for self-signed certs on internal domains) -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!-- Specific domain config for the internal .dom domain -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">fondazionesancarlo.dom</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>
</network-security-config>
